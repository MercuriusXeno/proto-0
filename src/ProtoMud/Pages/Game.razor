@page "/game"
@inject GameSessionHost Host
@inject NavigationManager Nav

<PageTitle>Proto-0</PageTitle>

@if (!Host.IsInitialized)
{
    <div class="loading-text">Redirecting...</div>
}
else
{
    <div class="game-layout">
        <div class="sidebar-left-top">
            <PlayerInfoPanel @ref="_playerInfoPanel" />
        </div>

        <div class="sidebar-left-bottom">
            <MapPanel @ref="_mapPanel" OnNavigate="HandleAction" />
        </div>

        <div class="main-area">
            <Terminal @ref="_terminal" OnCommandExecuted="RefreshPanels" AutoLookAfterMove="_autoLookAfterMove" />
            <div class="terminal-controls">
                <label class="auto-look-toggle">
                    <input type="checkbox" @bind="_autoLookAfterMove" />
                    Auto-look after navigation
                </label>
            </div>
            <ActionBar OnAction="HandleAction" />
        </div>

        <div class="sidebar-right">
            <TimeWidget @ref="_timeWidget" />
            <ActionLogPanel @ref="_actionLogPanel" />
        </div>
    </div>
}

@code {
    private Terminal? _terminal;
    private PlayerInfoPanel? _playerInfoPanel;
    private MapPanel? _mapPanel;
    private ActionLogPanel? _actionLogPanel;
    private TimeWidget? _timeWidget;
    private bool _autoLookAfterMove = true; // Default to enabled

    protected override void OnInitialized()
    {
        if (!Host.IsInitialized)
            Nav.NavigateTo("/");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Host.IsInitialized && _terminal is not null)
        {
            // Show initial room description
            var result = await Host.ProcessCommandAsync("look");
            _terminal.WriteRoomDescription(result, "");
            _terminal.WriteSystem("Type 'help' for a list of commands.");
            RefreshPanels();
            StateHasChanged();
        }
    }

    private async Task HandleAction(string command)
    {
        if (_terminal is null) return;

        var result = await Host.ProcessCommandAsync(command);
        var cssClass = result.Success ? "" : "error";

        // Check if this is a look command
        if (IsLookCommand(command))
        {
            _terminal.WriteRoomDescription(result, cssClass);
            _terminal.Clear(); // Clear action panel
        }
        else if (IsNavigationCommand(command))
        {
            _terminal.Clear();
            _terminal.WriteCommandResult(result, cssClass);

            // Auto-look after navigation if enabled
            if (_autoLookAfterMove)
            {
                var lookResult = await Host.ProcessCommandAsync("look");
                _terminal.WriteRoomDescription(lookResult, lookResult.Success ? "" : "error");
            }
        }
        else
        {
            _terminal.Clear();
            _terminal.WriteCommandResult(result, cssClass);

            // If command changed room state, refresh room description
            if (result.RefreshRoomDescription)
            {
                var lookResult = await Host.ProcessCommandAsync("look");
                _terminal.WriteRoomDescription(lookResult, lookResult.Success ? "" : "error");
            }
        }

        RefreshPanels();
        await _terminal.FocusInput();
    }

    private bool IsLookCommand(string command)
    {
        var commandLower = command.Trim().ToLowerInvariant();
        return commandLower == "look" || commandLower == "l" ||
               commandLower.StartsWith("look ") || commandLower.StartsWith("l ");
    }

    private bool IsNavigationCommand(string command)
    {
        var commandLower = command.Trim().ToLowerInvariant();
        return commandLower.StartsWith("go") || commandLower.StartsWith("move") ||
               commandLower is "north" or "south" or "east" or "west" or "up" or "down" or
               "n" or "s" or "e" or "w" or "u" or "d";
    }

    private void RefreshPanels()
    {
        _playerInfoPanel?.Refresh();
        _mapPanel?.Refresh();
        _actionLogPanel?.Refresh();
        _timeWidget?.Refresh();
    }
}
