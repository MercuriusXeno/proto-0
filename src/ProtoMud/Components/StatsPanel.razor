@inject GameSessionHost Host
@using ProtoEngine.Components

<div class="stats-panel panel">
    <h3>Attributes</h3>
    @if (_health is not null && _stats is not null)
    {
        <div class="stat-row">
            <span class="stat-label">HP</span>
            <div class="hp-bar">
                <div class="hp-fill" style="width: @HpPercent%"></div>
            </div>
            <span class="stat-value">@_health.Current/@_health.Max</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Level</span>
            <span class="stat-value">@_stats.Level</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">XP</span>
            <span class="stat-value">@_stats.Experience/@_stats.ExperienceToNextLevel</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Gold</span>
            <span class="stat-value">@_stats.Gold</span>
        </div>

        <div class="stats-divider"></div>

        <div class="stat-row">
            <span class="stat-label">Strength</span>
            <span class="stat-value">@_stats.Strength</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Agility</span>
            <span class="stat-value">@_stats.Agility</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Dexterity</span>
            <span class="stat-value">@_stats.Dexterity</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Perception</span>
            <span class="stat-value">@_stats.Perception</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Intelligence</span>
            <span class="stat-value">@_stats.Intelligence</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Willpower</span>
            <span class="stat-value">@_stats.Willpower</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Vitality</span>
            <span class="stat-value">@_stats.Vitality</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Charisma</span>
            <span class="stat-value">@_stats.Charisma</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Luck</span>
            <span class="stat-value">@_stats.Luck</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Memory</span>
            <span class="stat-value">@_stats.Memory</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Fate</span>
            <span class="stat-value">@_stats.Fate</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Eldritch</span>
            <span class="stat-value">@_stats.Eldritch</span>
        </div>
        <div class="stat-row">
            <span class="stat-label">Racial</span>
            <span class="stat-value">@_stats.Racial</span>
        </div>
    }
</div>

@code {
    private HealthComponent? _health;
    private StatsComponent? _stats;

    private int HpPercent => _health is not null && _health.Max > 0
        ? (int)(100.0 * _health.Current / _health.Max)
        : 0;

    public void Refresh()
    {
        if (Host.State is null) return;
        _health = Host.State.Player.Get<HealthComponent>();
        _stats = Host.State.Player.Get<StatsComponent>();
        StateHasChanged();
    }
}
