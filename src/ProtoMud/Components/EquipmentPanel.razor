@inject GameSessionHost Host
@using ProtoEngine.Components

<div class="equipment-panel panel">
    <h3>Equipment</h3>
    <div class="equipment-slots">
        @foreach (var region in GetEquipmentRegions())
        {
            <div class="equipment-region">
                <h4 class="region-name">@region.Name</h4>
                @foreach (var slot in region.Slots)
                {
                    <div class="equipment-slot">
                        <span class="slot-name">@GetSlotDisplayName(slot):</span>
                        <span class="slot-items">@GetSlotContents(slot)</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private record EquipmentRegion(string Name, EquipmentSlot[] Slots);

    public void Refresh()
    {
        StateHasChanged();
    }

    private List<EquipmentRegion> GetEquipmentRegions()
    {
        return new List<EquipmentRegion>
        {
            new("Wielding", new[] { EquipmentSlot.WieldLeft, EquipmentSlot.WieldRight }),
            new("Head", new[] { EquipmentSlot.Head, EquipmentSlot.Face, EquipmentSlot.Neck }),
            new("Torso", new[] { EquipmentSlot.Body, EquipmentSlot.Waist }),
            new("Arms", new[] { EquipmentSlot.LeftArm, EquipmentSlot.RightArm,
                               EquipmentSlot.LeftHand, EquipmentSlot.RightHand }),
            new("Legs", new[] { EquipmentSlot.Legs, EquipmentSlot.Feet }),
            new("Relics", new[] { EquipmentSlot.Relic1, EquipmentSlot.Relic2,
                                 EquipmentSlot.Relic3, EquipmentSlot.Relic4 })
        };
    }

    private string GetSlotDisplayName(EquipmentSlot slot)
    {
        return slot switch
        {
            EquipmentSlot.WieldLeft => "Wield Left",
            EquipmentSlot.WieldRight => "Wield Right",
            EquipmentSlot.LeftArm => "Left Arm",
            EquipmentSlot.RightArm => "Right Arm",
            EquipmentSlot.LeftHand => "Left Hand",
            EquipmentSlot.RightHand => "Right Hand",
            EquipmentSlot.Relic1 => "Relic I",
            EquipmentSlot.Relic2 => "Relic II",
            EquipmentSlot.Relic3 => "Relic III",
            EquipmentSlot.Relic4 => "Relic IV",
            _ => slot.ToString()
        };
    }

    private string GetSlotContents(EquipmentSlot slot)
    {
        if (Host.Session?.State?.Player is null)
            return "—";

        var equipment = Host.Session.State.Player.Get<EquipmentComponent>();
        if (equipment is null || equipment.IsSlotEmpty(slot))
        {
            // Show "(unarmed)" for empty wielding slots
            if (slot is EquipmentSlot.WieldLeft or EquipmentSlot.WieldRight)
                return "(unarmed)";
            return "—";
        }

        var items = equipment.GetSlotItems(slot);
        if (items.Count == 1)
            return items[0].ItemName;

        // Multiple items (layers)
        return string.Join(" / ", items.Select(i => i.ItemName));
    }
}
