@inject GameSessionHost Host
@using ProtoEngine.Components

<div class="equipment-panel panel">
    <div class="equipment-slots">
        @foreach (var slot in GetAllSlots())
        {
            <div class="equipment-slot">
                <span class="slot-name">@GetSlotDisplayName(slot):</span>
                <span class="slot-items">@GetSlotContents(slot)</span>
            </div>
        }
    </div>
</div>

@code {
    public void Refresh()
    {
        StateHasChanged();
    }

    private EquipmentSlot[] GetAllSlots()
    {
        return new[]
        {
            EquipmentSlot.WieldRight,
            EquipmentSlot.WieldLeft,
            EquipmentSlot.Head,
            EquipmentSlot.Body,
            EquipmentSlot.Arms,
            EquipmentSlot.Belt,
            EquipmentSlot.Legs,
            EquipmentSlot.Feet,
            EquipmentSlot.Accessory1,
            EquipmentSlot.Accessory2,
            EquipmentSlot.Accessory3
        };
    }

    private string GetSlotDisplayName(EquipmentSlot slot)
    {
        return slot switch
        {
            EquipmentSlot.WieldLeft => "Left",
            EquipmentSlot.WieldRight => "Right",
            EquipmentSlot.Accessory1 => "Acc 1",
            EquipmentSlot.Accessory2 => "Acc 2",
            EquipmentSlot.Accessory3 => "Acc 3",
            _ => slot.ToString()
        };
    }

    private string GetSlotContents(EquipmentSlot slot)
    {
        if (Host.Session?.State?.Player is null)
            return "—";

        var equipment = Host.Session.State.Player.Get<EquipmentComponent>();
        if (equipment is null || equipment.IsSlotEmpty(slot))
        {
            // Show "(unarmed)" for empty wielding slots
            if (slot is EquipmentSlot.WieldLeft or EquipmentSlot.WieldRight)
                return "(unarmed)";
            return "—";
        }

        var item = equipment.GetSlotItem(slot);
        return item?.ItemName ?? "—";
    }
}
