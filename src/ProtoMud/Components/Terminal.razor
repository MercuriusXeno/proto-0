@inject GameSessionHost Host
@using ProtoEngine.Commands

<div class="terminal">
    <div class="room-description-panel" @ref="_roomDescRef">
        @foreach (var line in _roomDescLines)
        {
            <div class="terminal-line @(line.CssClass)">
                @if (line.Entities.Count > 0)
                {
                    @RenderRichLine(line)
                }
                else
                {
                    @line.Text
                }
            </div>
        }
    </div>
    <div class="action-output-panel" @ref="_actionOutputRef">
        @foreach (var line in _actionOutputLines)
        {
            <div class="terminal-line @(line.CssClass)">
                @if (line.Entities.Count > 0)
                {
                    @RenderRichLine(line)
                }
                else
                {
                    @line.Text
                }
            </div>
        }
    </div>
    <div class="terminal-input-row">
        <span class="terminal-prompt">&gt;</span>
        <input @ref="_inputRef"
               class="terminal-input"
               type="text"
               @bind="_currentInput"
               @bind:event="oninput"
               @onkeydown="HandleKeyDown"
               placeholder="Enter a command..."
               autocomplete="off"
               spellcheck="false" />
    </div>
</div>

@code {
    [Parameter] public EventCallback OnCommandExecuted { get; set; }
    [Parameter] public bool AutoLookAfterMove { get; set; }

    private ElementReference _roomDescRef;
    private ElementReference _actionOutputRef;
    private ElementReference _inputRef;
    private string _currentInput = "";
    private readonly List<TerminalLine> _roomDescLines = new();
    private readonly List<TerminalLine> _actionOutputLines = new();
    private readonly List<string> _commandHistory = new();
    private int _historyIndex = -1;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _inputRef.FocusAsync();
        }
    }

    public void WriteLines(IEnumerable<string> lines, string cssClass = "")
    {
        foreach (var line in lines)
            _actionOutputLines.Add(new TerminalLine(line, cssClass, new()));
        StateHasChanged();
    }

    public void WriteCommandResult(CommandResult result, string cssClass = "")
    {
        WriteCommandResultToPanel(result, cssClass, _actionOutputLines);
        StateHasChanged();
    }

    public void WriteRoomDescription(CommandResult result, string cssClass = "")
    {
        _roomDescLines.Clear();
        WriteCommandResultToPanel(result, cssClass, _roomDescLines);
        StateHasChanged();
    }

    private void WriteCommandResultToPanel(CommandResult result, string cssClass, List<TerminalLine> targetList)
    {
        if (result.RichOutput.Count > 0)
        {
            foreach (var line in result.RichOutput)
                targetList.Add(new TerminalLine(line.Text, cssClass, line.Entities));
        }
        else
        {
            foreach (var line in result.Output)
                targetList.Add(new TerminalLine(line, cssClass, new()));
        }
    }

    public void WriteSystem(string text)
    {
        _actionOutputLines.Add(new TerminalLine(text, "system", new()));
        StateHasChanged();
    }

    public void Clear()
    {
        _actionOutputLines.Clear();
        StateHasChanged();
    }

    public void SetContent(IEnumerable<string> lines, string cssClass = "")
    {
        _actionOutputLines.Clear();
        foreach (var line in lines)
            _actionOutputLines.Add(new TerminalLine(line, cssClass, new()));
        StateHasChanged();
    }

    /// <summary>
    /// Executes a command string and routes the result to the appropriate panel.
    /// </summary>
    public async Task ExecuteCommand(string command)
    {
        var result = await Host.ProcessCommandAsync(command);
        RouteCommandResult(command, result);
        await OnCommandExecuted.InvokeAsync();
        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_currentInput))
        {
            var input = _currentInput.Trim();
            _currentInput = "";

            _commandHistory.Add(input);
            _historyIndex = _commandHistory.Count;

            await ExecuteCommand(input);
        }
        else if (e.Key == "ArrowUp")
        {
            if (_commandHistory.Count > 0 && _historyIndex > 0)
            {
                _historyIndex--;
                _currentInput = _commandHistory[_historyIndex];
            }
        }
        else if (e.Key == "ArrowDown")
        {
            if (_historyIndex < _commandHistory.Count - 1)
            {
                _historyIndex++;
                _currentInput = _commandHistory[_historyIndex];
            }
            else
            {
                _historyIndex = _commandHistory.Count;
                _currentInput = "";
            }
        }
    }

    private void RouteCommandResult(string command, CommandResult result)
    {
        var cssClass = result.Success ? "" : "error";

        if (CommandClassifier.IsLookCommand(command))
        {
            WriteRoomDescription(result, cssClass);
            _actionOutputLines.Clear();
        }
        else if (CommandClassifier.IsNavigationCommand(command))
        {
            _actionOutputLines.Clear();
            WriteCommandResultToPanel(result, cssClass, _actionOutputLines);
            AutoLookAfterNavigation();
        }
        else
        {
            _actionOutputLines.Clear();
            WriteCommandResultToPanel(result, cssClass, _actionOutputLines);
            if (result.RefreshRoomDescription)
                RefreshRoomDescription();
        }
    }

    private async void AutoLookAfterNavigation()
    {
        if (!AutoLookAfterMove)
            return;

        var lookResult = await Host.ProcessCommandAsync("look");
        WriteRoomDescription(lookResult, lookResult.Success ? "" : "error");
    }

    private async void RefreshRoomDescription()
    {
        var lookResult = await Host.ProcessCommandAsync("look");
        WriteRoomDescription(lookResult, lookResult.Success ? "" : "error");
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Yield();
        }
        catch { }
    }

    public async Task FocusInput()
    {
        await _inputRef.FocusAsync();
    }

    private async Task HandleEntityCommand(string command)
    {
        if (Host == null) return;
        await ExecuteCommand(command);
    }

    private RenderFragment RenderRichLine(TerminalLine line) => builder =>
    {
        var text = line.Text;
        var offset = 0;

        foreach (var entity in line.Entities)
        {
            var idx = text.IndexOf(entity.DisplayName, offset, StringComparison.OrdinalIgnoreCase);
            if (idx >= 0)
            {
                if (idx > offset)
                    builder.AddContent(0, text.Substring(offset, idx - offset));

                builder.OpenComponent<EntityButton>(1);
                builder.AddAttribute(2, "Entity", entity);
                builder.AddAttribute(3, "OnCommand", EventCallback.Factory.Create<string>(this, HandleEntityCommand));
                builder.CloseComponent();

                offset = idx + entity.DisplayName.Length;
            }
        }

        if (offset < text.Length)
            builder.AddContent(4, text.Substring(offset));
    };

    private record TerminalLine(string Text, string CssClass, List<EntityReference> Entities);
}
